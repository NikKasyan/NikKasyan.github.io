---
import type { EventDocument } from "../lib/content";
import { withBase } from "../lib/paths";

type Props = {
  event: EventDocument;
};

const { event } = Astro.props;

const formattedDate = new Intl.DateTimeFormat("en-AT", {
  dateStyle: "long",
  timeStyle: "short"
}).format(new Date(event.date));
const previewImage = event.titleImage || withBase("/media/assets/Logo-focus-no-background-black.png");
const previewClass = event.titleImage ? "event-card-preview" : "event-card-preview is-logo";
const previewPosition = event.titleImagePositionX !== undefined || event.titleImagePositionY !== undefined
  ? `${event.titleImagePositionX ?? 50}% ${event.titleImagePositionY ?? 50}%`
  : undefined;
---

<article class="event-card">
  <div class="event-card-head">
    <div class="event-card-copy">
      <div class="event-meta">
        <span>{formattedDate}</span>
        {event.tags.length > 0 && <span>{event.tags.join(" / ")}</span>}
      </div>

      <h3>
        <a href={withBase(`/events/${event.slug}/`)}>{event.title}</a>
      </h3>

      {(event.venue || event.organizer) && (
        <p class="event-context">
          {event.venue && <span>{event.venue}</span>}
          {event.venue && event.organizer && <span class="separator">•</span>}
          {event.organizer && <span>Organized by {event.organizer}</span>}
        </p>
      )}
    </div>

    <a class="event-card-image" href={withBase(`/events/${event.slug}/`)}>
      <img class={previewClass} src={previewImage} alt={event.title} style={previewPosition ? `object-position: ${previewPosition};` : undefined} />
    </a>
  </div>

  {event.body && <div class="event-summary" set:html={event.html} />}
</article>
