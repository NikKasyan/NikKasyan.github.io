---
type Props = {
  eyebrow?: string;
  title: string;
  lead?: string;
  imageSrc?: string;
  imageAlt?: string;
};

const { eyebrow, title, lead, imageSrc, imageAlt } = Astro.props;
const heroImageSrc = imageSrc || "/media/assets/Logo-focus-no-background-black.png";
const heroImageClass = imageSrc ? "page-hero-preview" : "page-hero-preview is-logo";
---

<section class="page-hero">
  <div class="page-hero-layout">
    <div class="page-hero-copy">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h1>{title}</h1>
      {lead && <p class="lead">{lead}</p>}
    </div>

    <div class="page-hero-media">
      <img class={heroImageClass} src={heroImageSrc} alt={imageAlt || title} />
    </div>
  </div>
</section>
