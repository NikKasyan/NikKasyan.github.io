---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import { getAdminRecords, getAdminSlideAssets } from "../../lib/admin-content";
import adminPanelUrl from "../../scripts/admin-panel.js?url";

const [initialRecords, slideAssets] = await Promise.all([getAdminRecords(), getAdminSlideAssets()]);
const adminPayload = JSON.stringify({ initialRecords, slideAssets });
---

<BaseLayout title="Admin | Vienna Symposium">
  <PageHero
    eyebrow="Editorial Tools"
    title="Admin"
    lead="Create, edit, and export file-backed content for events, venues, sliders, and organizer presets."
  />

  <section class="panel admin-panel">
    <div class="admin-shell">
      <aside class="admin-sidebar">
        <div class="admin-sidebar-section">
          <p class="eyebrow">Collections</p>
          <div class="admin-collection-tabs">
            <button type="button" class="admin-tab" data-collection-tab="events">Events</button>
            <button type="button" class="admin-tab" data-collection-tab="vendors">Venues</button>
            <button type="button" class="admin-tab" data-collection-tab="sliders">Sliders</button>
            <button type="button" class="admin-tab" data-collection-tab="organizers">Organizers</button>
          </div>
        </div>

        <div class="admin-sidebar-section">
          <p class="eyebrow">New</p>
          <div class="admin-create-actions">
            <button type="button" class="slider-button" data-create-record="events">New event</button>
            <button type="button" class="slider-button" data-create-record="vendors">New venue</button>
            <button type="button" class="slider-button" data-create-record="sliders">New slider</button>
            <button type="button" class="slider-button" data-create-record="organizers">New organizer</button>
          </div>
        </div>

        <div class="admin-sidebar-section admin-records-panel">
          <div class="admin-records-header">
            <p class="eyebrow">Files</p>
            <p id="admin-record-count" class="admin-muted"></p>
          </div>
          <div id="admin-record-list" class="admin-record-list"></div>
        </div>
      </aside>

      <div class="admin-main">
        <div class="admin-toolbar">
          <div>
            <p class="eyebrow">Export</p>
            <p class="admin-note">Edit content in memory, then export the current state as a ZIP containing the relevant <code>markdown/</code> folders.</p>
          </div>

          <div class="admin-toolbar-actions">
            <button id="admin-cancel-draft" type="button" class="slider-button admin-secondary" hidden>Cancel Draft</button>
            <button id="admin-download-zip" type="button" class="slider-button">Download ZIP</button>
          </div>
        </div>

        <div id="admin-status" class="admin-status" aria-live="polite"></div>

        <div class="admin-workflow-note">
          <p class="admin-note">Form mode updates the real source for each file. Source mode remains available whenever you need to inspect or correct the raw markdown or JSON.</p>
          <p class="admin-note">Slider form mode accepts dragged image files and maps them to <code>/media/assets/slides/&lt;filename&gt;</code>. The files are not uploaded here; their names are used to reference the assets you already placed in <code>markdown/assets/slides</code>.</p>
        </div>

        <div class="admin-editor-grid">
          <section class="admin-editor-card">
            <div class="admin-editor-header">
              <div>
                <p class="eyebrow">Selection</p>
                <h2 id="admin-record-title">No file selected</h2>
              </div>
              <div class="admin-editor-actions">
                <span id="admin-record-badge" class="admin-badge">Idle</span>
                <div class="admin-mode-toggle" id="admin-mode-toggle" hidden>
                  <button type="button" class="admin-mode-button is-active" data-editor-mode="form">Form</button>
                  <button type="button" class="admin-mode-button" data-editor-mode="source">Source</button>
                </div>
              </div>
            </div>

            <dl class="detail-list admin-detail-list">
              <div><dt>Collection</dt><dd id="admin-record-collection">-</dd></div>
              <div><dt>Relative path</dt><dd id="admin-record-path">-</dd></div>
              <div><dt>Slug</dt><dd id="admin-record-slug">-</dd></div>
              <div><dt>Date</dt><dd id="admin-record-date">-</dd></div>
            </dl>

            <div id="admin-form-host" class="admin-form-host"></div>

            <label id="admin-source-wrap" class="archive-control admin-source-label" hidden>
              <span>Source</span>
              <textarea id="admin-source" class="admin-source" spellcheck="false"></textarea>
            </label>
          </section>
        </div>
      </div>
    </div>
  </section>

  <script is:inline id="admin-data" type="application/json" set:html={adminPayload}></script>
  <script is:inline type="module" src={adminPanelUrl}></script>
</BaseLayout>
