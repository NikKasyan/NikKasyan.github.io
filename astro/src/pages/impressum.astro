---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { getImpressumPage } from "../lib/content";

const page = await getImpressumPage();
---

<BaseLayout title="Impressum | Vienna Symposium">
  <PageHero
    eyebrow="Legal"
    title="Impressum"
    lead="Publisher, association, and legal information."
  />

  <section class="panel panel-prose">
    <div class="prose" set:html={page.html} />
  </section>
</BaseLayout>
